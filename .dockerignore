# ─────────────────────────────────────────────────────────────
# .dockerignore — Rabih CRM
# Keeps the Docker build context lean and prevents secrets
# from being accidentally baked into images.
# ─────────────────────────────────────────────────────────────

# ── Python cache & build artifacts ────────────────────────────
venv/
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Secrets & environment ─────────────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ── Node / npm ────────────────────────────────────────────────
frontend/node_modules/
whatsapp-microservice/node_modules/
frontend/.vite/
frontend/dist/
node_modules/

# ── Version control ───────────────────────────────────────────
.git/
.git
.gitignore

# ── Notebooks & development data ─────────────────────────────
notebooks/
*.ipynb
*.csv
*.xlsx

# ── OS & IDE artifacts ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Docker files (don't nest Docker contexts) ─────────────────
docker-compose.yaml
docker-compose.prod.yml
.dockerignore

# ── Large documentation files (never needed in container) ─────
Docs/
*.pdf
*.pptx
*.mp4
*.mov

# ── ML artifacts (volume-mounted at runtime, not baked in) ────
artifacts/

# ── Development-only directories ──────────────────────────────
# scripts/ — diagnostic/admin helpers, not part of the API
scripts/
# helper_scripts/ — dev utilities
helper_scripts/
# tests/ — unit tests, not needed at runtime
tests/
# Rabih_CRM/ — likely sample data directory
Rabih_CRM/

# ── Documentation & markdown (not needed in container) ────────
*.md
!README.md

# ── Logs, temp files, databases ───────────────────────────────
*.log
*.db
*.sqlite
*.sqlite3
*.tmp
data/

# ── Alembic migration history (optional; keep if you run migrations in container) ──
# alembic/versions/   ← commented out; keep if you do DB migrations on startup
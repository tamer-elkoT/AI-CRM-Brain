# ==============================================================================
# AI CRM Brain - Environment Configuration Template (.env.example)
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env" in the same directory.
# 2. Replace the placeholder values with your own keys and credentials.
# 3. DO NOT commit the ".env" file to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. ZOHO CRM API CONFIGURATION
# ------------------------------------------------------------------------------
# These variables enable OAuth 2.0 authentication with the Zoho CRM API.
# Setup:
# - Go to the Zoho Developer Console (https://api-console.zoho.com).
# - Register a new "Server-based Application".
# - Configure the Redirect URI (e.g., http://localhost:8000/oauth2/callback).
# - Copy the Client ID and Client Secret generated by the console.

# Your Zoho Client ID
ZOHO_CLIENT_ID="your_zoho_client_id_here"

# Your Zoho Client Secret
ZOHO_CLIENT_SECRET="your_zoho_client_secret_here"

# The specific Zoho CRM API scopes required.
# Example: ZohoCRM.modules.deals.READ,ZohoCRM.modules.contacts.READ
SCOPE_NAME="ZohoCRM.modules.deals.READ,ZohoCRM.modules.contacts.READ"

# Zoho Refresh Token used to request new short-lived access tokens.
# Obtain this by completing the Zoho OAuth authorization code grant flow.
ZOHO_REFRESH_TOKEN="your_zoho_refresh_token_here"

# OAuth Redirect URI — must match exactly what you registered in the Zoho Developer Console.
# Register this at: https://api-console.zoho.com → Your App → Redirect URIs
ZOHO_REDIRECT_URI="http://localhost:8000/api/v1/auth/zoho/callback"


# ------------------------------------------------------------------------------
# 2. POSTGRESQL DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Credentials and database setup. These should align with your docker-compose.yaml settings.

# Username for PostgreSQL database access.
POSTGRES_USER="postgres"

# Password for PostgreSQL database access. Use a strong custom password.
POSTGRES_PASSWORD="your_postgres_password_here"

# Name of the target PostgreSQL database.
DB_NAME="ai_crm_brain"

# The port mapped to PostgreSQL. 
# Defaults to 5433 to prevent conflict with local Postgres installations (5432).
DB_PORT=5433


# ------------------------------------------------------------------------------
# 3. PGADMIN DATABASE MANAGEMENT UI
# ------------------------------------------------------------------------------
# Configuration settings for pgAdmin web console (Database GUI client).

# Administrator email for the pgAdmin web interface login.
PGADMIN_EMAIL="admin@example.com"

# Administrator password for the pgAdmin web interface login.
PGADMIN_PASSWORD="your_pgadmin_password_here"


# ------------------------------------------------------------------------------
# 4. GROQ LARGE LANGUAGE MODEL (LLM) CONFIGURATION
# ------------------------------------------------------------------------------
# Settings for using Groq API as the primary/fallback LLM provider.
# Setup:
# - Create an account on the Groq Console (https://console.groq.com).
# - Go to "API Keys" and generate a new API key.

# Your Groq API Key (begins with gsk_...)
LLM_API_KEY="your_groq_api_key_here"

# The provider identifier. Default: groq
LLM_PROVIDER="groq"

# The specific model ID to request from Groq.
# Default: llama-3.3-70b-versatile
LLM_MODEL_ID="llama-3.3-70b-versatile"

# Base API endpoint for Groq (OpenAI-compatible).
# Default: https://api.groq.com/openai/v1
LLM_BASE_URL="https://api.groq.com/openai/v1"

# Maximum number of tokens allowed for LLM inference response.
LLM_MAX_TOKENS=500

# Randomness of the model outputs (0.0 is deterministic, 1.0 is creative).
LLM_TEMPERATURE=0.3


# ------------------------------------------------------------------------------
# 5. GROK (xAI) LLM CONFIGURATION
# ------------------------------------------------------------------------------
# Configuration for the primary recommendations generator model using x.ai's Grok API.
# Setup:
# - Create an account on the xAI Console (https://console.x.ai).
# - Generate an API key in the API section.

# Your xAI/Grok API Key (begins with xai-...)
GROK_API_KEY="your_grok_api_key_here"

# Base API endpoint for xAI.
# Default: https://api.x.ai/v1
GROK_BASE_URL="https://api.x.ai/v1"

# Model name to request from xAI.
# Default: grok-3-latest
GROK_MODEL="grok-3-latest"


# ------------------------------------------------------------------------------
# 6. JWT SECURITY & BASE APP SETTINGS
# ------------------------------------------------------------------------------

# Secret key used for signing JWT access tokens (must be a secure 32-byte hex string).
# You can generate a fresh one via Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="generate_and_replace_with_a_secure_random_64_character_hex_string"

# Token signing algorithm. Default: HS256
ALGORITHM="HS256"

# Token lifespan in minutes. (10080 minutes = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Base URL of the React/Vite Frontend dashboard app.
APP_BASE_URL="http://localhost:5173"

# Base URL of the FastAPI Backend server.
API_BASE_URL="http://localhost:8000"

# Background recommendation engine batch interval execution frequency in minutes.
BATCH_INTERVAL_MINUTES=30


# ------------------------------------------------------------------------------
# 7. TWILIO NOTIFICATION SERVICE (WHATSAPP)
# ------------------------------------------------------------------------------
# Credentials for sending automated WhatsApp recommendations to users via Twilio.
# Setup:
# - Sign up for a Twilio account (https://console.twilio.com).
# - Locate "Account SID" and "Auth Token" on the Console home page dashboard.
# - Go to "Messaging" -> "Try it out" -> "Send a WhatsApp message" to configure your Sandbox.

# Twilio Account String Identifier (begins with AC...)
TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"

# Twilio Authentication Token
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"

# Twilio WhatsApp Sender Number (including "whatsapp:" prefix).
# Sandbox test number: whatsapp:+14155238886 (verify in Twilio dashboard).
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"


# ------------------------------------------------------------------------------
# 8. SMTP EMAIL SERVICE (For Team Invites)
# ------------------------------------------------------------------------------
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM="noreply@aicrmbrain.com"
# ─────────────────────────────────────────────────────────────
# frontend/.dockerignore
# Keeps the React/Vite build context lean.
# Context root is ./frontend (set in docker-compose.prod.yml)
# ─────────────────────────────────────────────────────────────

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output (generated fresh inside Docker) ──────────────
dist/
.vite/
build/

# ── OS & IDE ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Environment & secrets ─────────────────────────────────────
.env
.env.*
.env.local
.env.production.local

# ── Logs ──────────────────────────────────────────────────────
*.log

# ── Tests ─────────────────────────────────────────────────────
**/__tests__/
**/*.test.ts
**/*.spec.ts
coverage/

# ─────────────────────────────────────────────────────────────
# frontend/.env.example — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# All VITE_* variables are embedded at build time by Vite.
# Set these in the Vercel dashboard for production builds.
# ─────────────────────────────────────────────────────────────

# URL of the FastAPI backend API.
# Local dev: http://localhost:8000/api/v1
# Production (Vercel): https://your-backend-project.vercel.app/api/v1
VITE_API_URL=http://localhost:8000/api/v1
